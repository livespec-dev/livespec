{
  "name": "@livespec/vscode",
  "displayName": "LiveSpec",
  "version": "0.1.0",
  "description": "LiveSpec VS Code extension",
  "publisher": "livespec",
  "private": true,
  "type": "module",
  "engines": {
    "vscode": "^1.97.0"
  },
  "main": "./dist/extension.cjs",
  "files": [
    "dist",
    "webview/dist",
    "media"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:livespec.openSpec",
    "onCommand:livespec.refreshSpecTree",
    "onCommand:livespec.revealActiveSpec",
    "onCommand:livespec.copySelectedIds",
    "onCommand:livespec.toggleIncompleteOnly",
    "onCommand:livespec.editSource",
    "onCommand:livespec.refresh",
    "onCustomEditor:livespec.preview",
    "onView:livespec.specTree"
  ],
  "contributes": {
    "commands": [
      {
        "command": "livespec.openSpec",
        "title": "LiveSpec: Open Spec...",
        "icon": {
          "light": "media/open-spec-light.svg",
          "dark": "media/open-spec-dark.svg"
        }
      },
      {
        "command": "livespec.refreshSpecTree",
        "title": "LiveSpec: Refresh Spec Tree",
        "icon": {
          "light": "media/refresh-spec-tree-light.svg",
          "dark": "media/refresh-spec-tree-dark.svg"
        }
      },
      {
        "command": "livespec.revealActiveSpec",
        "title": "LiveSpec: Reveal Active Spec",
        "icon": {
          "light": "media/reveal-active-spec-light.svg",
          "dark": "media/reveal-active-spec-dark.svg"
        }
      },
      {
        "command": "livespec.copySelectedIds",
        "title": "LiveSpec: Copy Selected IDs"
      },
      {
        "command": "livespec.toggleIncompleteOnly",
        "title": "LiveSpec: Toggle Incomplete Only"
      },
      {
        "command": "livespec.editSource",
        "title": "LiveSpec: Edit Source"
      },
      {
        "command": "livespec.refresh",
        "title": "LiveSpec: Refresh"
      }
    ],
    "customEditors": [
      {
        "viewType": "livespec.preview",
        "displayName": "LiveSpec",
        "selector": [
          {
            "filenamePattern": "**/*.md"
          }
        ],
        "priority": "option"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "livespec",
          "title": "LiveSpec",
          "icon": "media/livespec-activity.svg"
        }
      ]
    },
    "views": {
      "livespec": [
        {
          "id": "livespec.specTree",
          "name": "Specs"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "livespec.openSpec",
          "when": "view == livespec.specTree",
          "group": "navigation@1"
        },
        {
          "command": "livespec.refreshSpecTree",
          "when": "view == livespec.specTree",
          "group": "navigation@2"
        },
        {
          "command": "livespec.revealActiveSpec",
          "when": "view == livespec.specTree",
          "group": "navigation@3"
        }
      ]
    }
  },
  "scripts": {
    "build": "pnpm --filter @livespec/core build && pnpm run build:extension && pnpm run build:webview",
    "build:extension": "tsup src/extension.ts --format cjs --target node20 --out-dir dist --external vscode --sourcemap --minify-whitespace",
    "build:webview": "vite build",
    "test": "pnpm --filter @livespec/core build && vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p webview/tsconfig.json --noEmit",
    "clean": "rm -rf dist coverage webview/dist"
  },
  "dependencies": {
    "@livespec/core": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.0.0",
    "remark-gfm": "^4.0.1"
  }
}